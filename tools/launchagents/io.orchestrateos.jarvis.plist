<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.orchestrateos.jarvis</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd "$HOME/Library/Application Support/OrchestrateOS" &amp;&amp; python3 -m uvicorn jarvis:app --host 0.0.0.0 --port 5004 &gt;&gt; "$HOME/Library/Logs/OrchestrateOS/jarvis.log" 2&gt;&gt; "$HOME/Library/Logs/OrchestrateOS/jarvis_error.log"</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
