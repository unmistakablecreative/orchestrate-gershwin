{
  "metadata": {
    "description": "Gershwin Test Suite Configuration",
    "version": "1.0",
    "notes": "Add or remove tests by editing this file. Each test requires tool_name, action, params, criteria, and description."
  },
  "tests": [
    {
      "id": "1.1",
      "section": "docs",
      "section_title": "docs Tool",
      "description": "Create a test document",
      "tool_name": "docs",
      "action": "create_doc",
      "params": {
        "title": "Test Doc Alpha",
        "content": "This is test content for validation.",
        "collection": "Test"
      },
      "criteria": [
        {"type": "status", "value": "success"},
        {"type": "has_field", "field": "doc_id"}
      ],
      "store_field": "doc_id",
      "store_as": "doc_id"
    },
    {
      "id": "1.2",
      "section": "docs",
      "description": "Read the created document",
      "tool_name": "docs",
      "action": "read_doc",
      "params": {
        "doc_id": "<DOC_ID>"
      },
      "criteria": [
        {"type": "status", "value": "success"},
        {"type": "field_contains", "field": "content", "contains": "test content for validation"}
      ]
    },
    {
      "id": "1.3",
      "section": "docs",
      "description": "Append content to document",
      "tool_name": "docs",
      "action": "append_doc",
      "params": {
        "doc_id": "<DOC_ID>",
        "content": "\n\nAppended paragraph for testing."
      },
      "criteria": [
        {"type": "status", "value": "success"}
      ]
    },
    {
      "id": "1.4",
      "section": "docs",
      "description": "Update document with find/replace",
      "tool_name": "docs",
      "action": "update_doc",
      "params": {
        "doc_id": "<DOC_ID>",
        "find": "test content",
        "replace": "REPLACED content"
      },
      "criteria": [
        {"type": "status", "value": "success"}
      ]
    },
    {
      "id": "1.5",
      "section": "docs",
      "description": "Search documents by query",
      "tool_name": "docs",
      "action": "search_docs",
      "params": {
        "query": "Alpha"
      },
      "criteria": [
        {"type": "status", "value": "success"},
        {"type": "has_field", "field": "docs"}
      ]
    },
    {
      "id": "1.6",
      "section": "docs",
      "description": "List documents in collection",
      "tool_name": "docs",
      "action": "list_docs",
      "params": {
        "collection": "Test"
      },
      "criteria": [
        {"type": "status", "value": "success"},
        {"type": "has_field", "field": "docs"}
      ]
    },
    {
      "id": "1.7",
      "section": "docs",
      "description": "Delete the test document",
      "tool_name": "docs",
      "action": "delete_doc",
      "params": {
        "doc_id": "<DOC_ID>"
      },
      "criteria": [
        {"type": "status", "value": "success"}
      ],
      "clear_state": "doc_id"
    },
